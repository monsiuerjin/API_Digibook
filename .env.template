# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIAL_PATH=firebase-credentials.json
ASPNETCORE_ENVIRONMENT=Development

# Chatbot (Gemini)
# Option 1: Simple key used by GeminiClient fallback
GEMINI_API_KEY=replace-with-your-google-ai-studio-key

# Option 2: Hierarchical config binding for ChatbotOptions
# Chatbot__GeminiApiKey=replace-with-your-google-ai-studio-key
# Chatbot__GeminiModel=gemini-1.5-flash
# Chatbot__EnableGeminiFallback=true
# Chatbot__FallbackConfidenceThreshold=0.65
# Chatbot__MaxCandidatesForPrompt=6
# Chatbot__MaxOutputTokens=300
# Chatbot__CacheMinutes=20
# Chatbot__MaxPromptTokens=2000
